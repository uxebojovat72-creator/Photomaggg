# Copy this to /opt/priceradar/.env on your server and fill in real values

# PostgreSQL (use this for cloud Neon testing, or see docker-compose.prod.yml for self-hosted)
DATABASE_URL=postgresql://priceradar:YOUR_DB_PASSWORD@localhost:5432/priceradar

# Redis (use this for cloud Upstash testing, or redis://:PASSWORD@redis:6379 for self-hosted)
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@your-upstash-host:6379

# JWT secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MIN

# Your frontend URL (Cloudflare Pages)
CORS_ORIGINS=https://your-project.pages.dev
FRONTEND_URL=https://your-project.pages.dev

# API server settings
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# ─── For docker-compose.prod.yml (self-hosted) ───────────────────────────────
# POSTGRES_PASSWORD=strong_password_here
# REDIS_PASSWORD=strong_password_here
