# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=priceradar
POSTGRES_PASSWORD=priceradar_secret
POSTGRES_DB=priceradar
DATABASE_URL="postgresql://priceradar:priceradar_secret@localhost:5432/priceradar"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Storage (Supabase or S3-compatible) ─────────────────────────────────────
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_STORAGE_BUCKET=priceradar-photos

# AWS S3 fallback
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=priceradar-photos

# ─── AI Recognition ──────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_your_key_here
HUGGINGFACE_MODEL=Salesforce/blip-image-captioning-large

GOOGLE_CLOUD_VISION_API_KEY=your_google_vision_key

# ─── Currency API ─────────────────────────────────────────────────────────────
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest

# ─── Push Notifications ───────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@priceradar.app

FCM_SERVER_KEY=

# ─── Email (MailHog in dev / SMTP in prod) ───────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@priceradar.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_GUEST=100
RATE_LIMIT_AUTH=300

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=
